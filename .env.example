# Slack app tokens — create the "Clockwork" app at https://api.slack.com/apps
# (use manifest.json in this repo), install to your sandbox, then:
#   Bot token:  OAuth & Permissions -> Bot User OAuth Token (xoxb-...)
#   App token:  Basic Information -> App-Level Tokens -> create with connections:write (xapp-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token

# Optional: xoxp user token with search:read.* scopes — enables the Real-Time
# Search API path (assistant.search.context). Get it from OAuth & Permissions
# -> User OAuth Token after installing with user scopes.
SLACK_USER_TOKEN=

# LLM key for intent parsing + agenda/handover drafting.
# Anthropic is checked first, then OpenAI. If neither is set, Clockwork
# falls back to deterministic parsing (demo still works).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Timezone all calendars/demo run in.
SCHEDULER_TZ=America/Los_Angeles

# Which team member "you" are in the demo calendars.
CADENCE_ME=alex@cadence.demo

# Deja Vu: how old a message must be to count as "prior discussion".
# Default 86400 (24h). Set 0 when the channel was seeded the same day as the demo.
CADENCE_DEJAVU_MIN_AGE_SECONDS=0

# Set to 1 to let Deja Vu post quiet in-thread hints on live channel messages.
CADENCE_LIVE_SCAN=0

# Daily digest: channel name, hour (local TZ). CADENCE_DIGEST_ON_START=1 posts
# one immediately at startup (great for demos). Empty channel disables it.
CADENCE_DIGEST_CHANNEL=general
CADENCE_DIGEST_HOUR=9
CADENCE_DIGEST_ON_START=1
